# === Backend Environment Variables ===

# Port for the Express server (Cloud Run sets this automatically)
PORT=8080

# Firebase project ID — must match your Firebase Console project
FIREBASE_PROJECT_ID=civicguide-demo

# Path to your Firebase service account JSON key file
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# On Cloud Run, this is handled automatically via the service's IAM identity
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
